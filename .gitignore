# Environment and secrets (never commit)
.env
.env.*
!.env.example

# OS junk
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# Editor / IDE local (keep shared .vscode/ if you commit team settings)
*.code-workspace
.idea/
*.suo
*.user
*.userosscache

# Logs and temp
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.tmp
*.temp
*~
*.swp
*.swo

# Node (npx skills, local tooling)
node_modules/

# Python (if scripts or tooling add it later)
__pycache__/
*.py[cod]
.venv/
venv/
.Python

# PowerShell / coverage
*.ps1xml

# Windows alternate data streams (rare)
*:Zone.Identifier

# ---------------------------------------------------------------------------
# Optional local-only markdown (design notes, private checklists, overlays).
# Canonical tier/porting/releasing/evidence content lives in README.md.
# If these paths were ever tracked: git rm --cached SIGNAL-design.md RELEASING.md EVIDENCE.md WHEN-TO-USE.md PORTING.md
# ---------------------------------------------------------------------------
/SIGNAL-design.md
/RELEASING.md
/EVIDENCE.md
/WHEN-TO-USE.md
/PORTING.md

# Benchmark harness — versioned scripts + docs; local run artifacts stay ignored
benchmark/*
!benchmark/README.md
!benchmark/run.ps1
!benchmark/proof-suite.ps1
!benchmark/fixtures/
!benchmark/fixtures/**
!benchmark/results/
!benchmark/results/v0.4-static.json
benchmark/results/local/
!benchmark/lib/
!benchmark/lib/**
# Long-session runner + scenario (ignore generated JSON log and RESULTS append)
!benchmark/long-session/
!benchmark/long-session/README.md
!benchmark/long-session/run_long_session.ps1
!benchmark/long-session/turns.json
benchmark/long-session/results_*.json
benchmark/long-session/RESULTS.md
# Gemini CLI chess pair harness + fixtures + optional proof JSON
!benchmark/benchmark chess/
!benchmark/benchmark chess/**
# Optional ckpt compression helper
!benchmark/ckpt-compression/
!benchmark/ckpt-compression/**
