{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "node ./hooks/signal-session-reminder.js",
            "timeout": 15,
            "statusMessage": "SIGNAL session defaults"
          }
        ]
      }
    ]
  }
}
